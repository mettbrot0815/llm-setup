#!/usr/bin/env bash
# llm-switch — switch active Ollama model, no reinstall needed
set -uo pipefail

RED=$'\033[0;31m'  GREEN=$'\033[0;32m'  YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m' BOLD=$'\033[1m'      DIM=$'\033[2m'        NC=$'\033[0m'
BGREEN=$'\033[1;32m' BYELLOW=$'\033[1;33m' BCYAN=$'\033[1;36m' BRED=$'\033[1;31m'
[[ -t 1 ]] || { RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; DIM=''; NC=''; BGREEN=''; BYELLOW=''; BCYAN=''; BRED=''; }

CONF="$HOME/.config/llm-setup/model.conf"

echo ""
echo -e "  ${BOLD}Model Switcher${NC}  ${DIM}──────────────────────────────────────────────${NC}"
echo ""

# Show current
if [[ -f "$CONF" ]]; then
  source "$CONF" 2>/dev/null
  echo -e "  ${DIM}Current:${NC}  ${OLLAMA_TAG:-none}"
fi

# Ensure Ollama is running
if ! curl -sf http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
  echo -e "  ${DIM}Starting Ollama…${NC}"
  if grep -qi microsoft /proc/version 2>/dev/null; then
    nohup ollama serve >/dev/null 2>&1 & disown $!
  else
    if ! sudo systemctl start ollama 2>/dev/null; then
      nohup ollama serve >/dev/null 2>&1 & disown $!
    fi
  fi
  for i in {1..12}; do
    curl -sf http://127.0.0.1:11434/api/tags >/dev/null 2>&1 && break
    sleep 1
  done
fi

# Build list of installed models
mapfile -t TAGS < <(ollama list 2>/dev/null | awk 'NR>1 && $1!="" {print $1}')

if [[ ${#TAGS[@]} -eq 0 ]]; then
  echo -e "  ${BYLW}No models installed.${NC}"
  echo -e "  Download one:  ${CYAN}ollama pull qwen3:8b${NC}"
  echo -e "  Or run:        ${CYAN}llm-add${NC}"
  exit 0
fi

echo -e "  ${BOLD}Installed models:${NC}"
for i in "${!TAGS[@]}"; do
  local_flag=""
  # Mark models registered from local GGUF files
  ollama show "${TAGS[$i]}" 2>/dev/null | grep -q "FROM.*\.gguf" && local_flag="  ${DIM}(local GGUF)${NC}"
  printf "  ${CYAN}%2d)${NC}  %s%s\n" "$(( i + 1 ))" "${TAGS[$i]}" "$local_flag"
done
echo ""

read -r -p "  Choice [1-${#TAGS[@]}] (Enter to cancel): " choice
choice=$(echo "$choice" | tr -dc '0-9')
[[ -z "$choice" ]] && echo "  Cancelled." && exit 0

if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#TAGS[@]} )); then
  echo -e "  ${BRED}Invalid choice.${NC}" >&2; exit 1
fi

NEW_TAG="${TAGS[$(( choice - 1 ))]}"

# Update config
mkdir -p "$(dirname "$CONF")"
if [[ -f "$CONF" ]]; then
  sed -i "s|^OLLAMA_TAG=.*|OLLAMA_TAG=\"$NEW_TAG\"|" "$CONF"
  sed -i "s|^MODEL_NAME=.*|MODEL_NAME=\"$NEW_TAG\"|" "$CONF"
  grep -q "^OLLAMA_TAG=" "$CONF" || echo "OLLAMA_TAG=\"$NEW_TAG\"" >> "$CONF"
else
  echo "OLLAMA_TAG=\"$NEW_TAG\"" > "$CONF"
fi

echo ""
echo -e "  ${BGREEN}✔${NC}  Switched to: ${BOLD}$NEW_TAG${NC}"
echo -e "  ${DIM}Run:${NC}  ollama run $NEW_TAG"
echo -e "  ${DIM}Or:${NC}   chat    (oterm)"
echo ""
