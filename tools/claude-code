#!/usr/bin/env bash
# tools/claude-code — wrapper for Claude Code → local Anthropic adapter
set -uo pipefail

CONF_DIR="$HOME/.config/llm-setup"
source "$CONF_DIR/keys.env"   2>/dev/null || true
source "$CONF_DIR/model.conf" 2>/dev/null || true
source "$CONF_DIR/mcp.conf"   2>/dev/null || true

# ── GPU enforcement ───────────────────────────────────────────────────────────
_LIB="$HOME/.local/share/llm-setup/lib"
[[ -f "$_LIB/gpu-ensure.sh" ]] && source "$_LIB/gpu-ensure.sh" && _gpu_ensure "${OLLAMA_TAG:-}"

_CLAUDE="$HOME/.local/bin/claude"
[[ -x "$_CLAUDE" ]] || {
  echo -e "  \033[1;31m[!]\033[0m  claude binary not found at $_CLAUDE"
  echo -e "       Install: curl -fsSL https://claude.ai/install.sh | sh"
  exit 1
}

export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-local}"
export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-http://127.0.0.1:4010}"

# Check adapter is running
curl -sf --max-time 2 "http://127.0.0.1:4010/v1/models" >/dev/null 2>&1 || {
  echo -e "  \033[1;33m[~]\033[0m  Adapter not running — starting..."
  systemctl --user start llm-adapter.service 2>/dev/null || {
    OLLAMA_BASE=http://127.0.0.1:11434 ADAPTER_PORT=4010 \
    OLLAMA_MODEL="${OLLAMA_TAG:-qwen3:14b}" \
    nohup python3 "$HOME/.local/bin/llm-anthropic-adapter" \
      >> "$CONF_DIR/adapter.log" 2>&1 &
    disown 2>/dev/null
    sleep 2
  }
}

# Register MCP servers in ~/.claude.json
_MCP_TIME_PORT="${MCP_TIME_PORT:-8010}"
_MCP_FS_PORT="${MCP_FS_PORT:-8011}"
_FS_DIRS=$(cat "$CONF_DIR/mcp_fs_dirs.txt" 2>/dev/null \
  | python3 -c "import sys,json; print(json.dumps([l.strip() for l in sys.stdin if l.strip()]))" \
  2>/dev/null || echo "[\"$HOME\"]")

python3 - << MCPPY 2>/dev/null || true
import json, os
f = os.path.expanduser("~/.claude.json")
cfg = json.load(open(f)) if os.path.exists(f) else {}
cfg.setdefault("mcpServers", {})
cfg["mcpServers"]["time"]       = {"type":"sse","url":"http://127.0.0.1:${_MCP_TIME_PORT}/sse"}
cfg["mcpServers"]["filesystem"] = {"type":"sse","url":"http://127.0.0.1:${_MCP_FS_PORT}/sse"}
json.dump(cfg, open(f,"w"), indent=2)
MCPPY

echo -e "  \033[1;32m[+]\033[0m  claude-code → local adapter :4010 → Ollama"
echo -e "  \033[2m      MCP: time :${_MCP_TIME_PORT}  filesystem :${_MCP_FS_PORT}\033[0m"
echo ""

exec "$_CLAUDE" --dangerously-skip-permissions "$@"
