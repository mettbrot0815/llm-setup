#!/usr/bin/env bash
# llm-add вҖ” interactive model downloader with hardware-aware picker
set -uo pipefail

RED=$'\033[0;31m'  GREEN=$'\033[0;32m'  YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m' BOLD=$'\033[1m'      DIM=$'\033[2m'        NC=$'\033[0m'
BGREEN=$'\033[1;32m' BYELLOW=$'\033[1;33m' BCYAN=$'\033[1;36m' BRED=$'\033[1;31m'
[[ -t 1 ]] || { RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; DIM=''; NC=''; BGREEN=''; BYELLOW=''; BCYAN=''; BRED=''; }

# Resolve lib dir relative to this script, then fall back to installed copy
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_LIB_DIR=""
for _d in "$_SCRIPT_DIR/../lib" "$HOME/.local/share/llm-setup/lib"; do
  [[ -f "$_d/ui.sh" ]] && _LIB_DIR="$_d" && break
done
if [[ -z "$_LIB_DIR" ]]; then
  echo "Cannot find lib/ вҖ” re-run llm-setup" >&2; exit 1
fi

# shellcheck source=/dev/null
source "$_LIB_DIR/ui.sh"
source "$_LIB_DIR/detect.sh" && detect_hardware
source "$_LIB_DIR/catalog.sh"

echo ""
echo -e "  ${BOLD}Add a Model${NC}  ${DIM}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}"
echo ""

INSTALLED_MODELS=()
if command -v ollama &>/dev/null; then
  mapfile -t INSTALLED_MODELS < <(ollama list 2>/dev/null | awk 'NR>1 && $1!="" {print $1}')
fi

echo -e "  ${DIM}в”Ңв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
printf  "  в”Ӯ %2s в”Ӯ %-29s в”Ӯ %-4s в”Ӯ %-5s в”Ӯ %-20s в”Ӯ\n" "#" "Model" "Quant" "VRAM" "Capabilities"
echo -e "  ${DIM}в”ңв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${NC}"

for (( _i=0; _i<${#_MODELS[@]}; _i++ )); do
  _parse_row "${_MODELS[$_i]}"
  _vram_disp="${_M[vram]}"
  [[ "$_vram_disp" != "CPU" ]] && _vram_disp="~${_vram_disp}GB"

  _installed_mark=""
  for _t in "${INSTALLED_MODELS[@]:-}"; do
    [[ "$_t" == "${_M[tag]}"* ]] && _installed_mark="  ${DIM}вң”${NC}" && break
  done

  _color=""
  if [[ "${_M[vram]}" == "CPU" ]] || { [[ "${_M[vram]}" =~ ^[0-9]+$ ]] && (( HAS_GPU && GPU_VRAM_GB >= _M[vram] )); }; then
    _color="${GREEN}"
  fi

  _caps_disp=$(_caps_label "${_M[caps]}")
  printf "  в”Ӯ${_color} %2d${NC} в”Ӯ %-29s в”Ӯ %-4s в”Ӯ %-5s в”Ӯ %-20s в”Ӯ\n" \
    "$(( _i + 1 ))" "${_M[name]:0:29}" "${_M[quant]}" "$_vram_disp" "${_caps_disp:0:20}"
done
echo -e "  ${DIM}в””в”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}"
echo ""
echo -e "  ${DIM}${GREEN}Green${NC} ${DIM}= fits your hardware  вң” = already installed${NC}"
echo ""

read -r -p "  Choice [1-${#_MODELS[@]}] or Enter to cancel: " choice
[[ -z "$choice" ]] && echo "  Cancelled." && exit 0

if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#_MODELS[@]} )); then
  echo -e "  ${BRED}Invalid choice.${NC}" >&2; exit 1
fi

_parse_row "${_MODELS[$(( choice - 1 ))]}"
TAG="${_M[tag]}"

if ollama show "$TAG" &>/dev/null; then
  echo -e "  ${BGREEN}вң”${NC}  Already installed: $TAG"
  echo -e "  ${DIM}Use:${NC}  ollama run $TAG"
  echo -e "  ${DIM}Set as default:${NC}  llm-switch"
  exit 0
fi

echo ""
echo -e "  ${BOLD}в¬Ү  ollama pull $TAG${NC}  (~${_M[size_gb]} GB)"
echo ""
ollama pull "$TAG"
_rc=$?

if (( _rc == 0 )); then
  echo -e "  ${BGREEN}вң”${NC}  Downloaded: $TAG"
  echo -e "  ${DIM}Set as default:${NC}  llm-switch"
  echo -e "  ${DIM}Run now:${NC}  ollama run $TAG"
else
  echo -e "  ${BRED}вңҳ${NC}  Pull failed (exit $_rc)" >&2
  exit 1
fi
