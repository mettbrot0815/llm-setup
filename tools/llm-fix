#!/usr/bin/env bash
# tools/llm-fix — auto-repair common llm-setup issues
set -uo pipefail

CONF_DIR="$HOME/.config/llm-setup"
BIN_DIR="$HOME/.local/bin"
source "$CONF_DIR/model.conf" 2>/dev/null || true

C='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'; DIM='\033[2m'
BG='\033[1;32m'; BR='\033[1;31m'; BY='\033[1;33m'; BC='\033[1;36m'
ok()   { echo -e "  ${BG}[+]${NC}  $1"; }
fail() { echo -e "  ${BR}[!]${NC}  $1"; }
warn() { echo -e "  ${BY}[~]${NC}  $1"; }
info() { echo -e "  ${BC}[*]${NC}  $1"; }

echo ""
echo -e "  ${BOLD}llm-fix — auto repair${NC}"
echo -e "  ${DIM}────────────────────────────────────────${NC}"
echo ""

FIXED=0; UNFIXED=0


# Ollama lib permissions (common WSL2 GPU issue)
if [[ -d /usr/local/lib/ollama ]]; then
  sudo chmod -R 755 /usr/local/lib/ollama/ 2>/dev/null \
    && ok "Ollama lib permissions" \
    || warn "Ollama lib permissions — run manually: sudo chmod -R 755 /usr/local/lib/ollama/"
fi

# Ollama service
if ! curl -sf http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
  warn "Ollama not responding — restarting..."
  sudo systemctl restart ollama 2>/dev/null || nohup ollama serve &>/dev/null &
  sleep 3
  curl -sf http://127.0.0.1:11434/api/tags >/dev/null 2>&1 \
    && ok "Ollama restarted" \
    || fail "Ollama still not responding — check: journalctl -u ollama"
else
  ok "Ollama — online"
fi

# Anthropic adapter
if ! curl -sf --max-time 2 http://127.0.0.1:4010/v1/models >/dev/null 2>&1; then
  warn "Anthropic adapter not running — starting..."
  systemctl --user start llm-adapter.service 2>/dev/null || {
    source "$CONF_DIR/model.conf" 2>/dev/null || true
    OLLAMA_BASE=http://127.0.0.1:11434 ADAPTER_PORT=4010 \
    OLLAMA_MODEL="${OLLAMA_TAG:-qwen2.5:14b}" \
    nohup python3 "$BIN_DIR/llm-anthropic-adapter" \
      >> "$CONF_DIR/adapter.log" 2>&1 &
    disown 2>/dev/null
  }
  sleep 2
  curl -sf --max-time 2 http://127.0.0.1:4010/v1/models >/dev/null 2>&1 \
    && ok "Anthropic adapter started" \
    || fail "Adapter failed — check $CONF_DIR/adapter.log"
else
  ok "Anthropic adapter — online"
fi

# MCP bridges
MCP_VENV="${MCP_VENV:-$HOME/.local/share/mcp-venv}"
# Ensure mcp-server-time is installed (may be missing from older setups)
if [[ -x "$MCP_VENV/bin/pip" ]] && [[ ! -x "$MCP_VENV/bin/mcp-server-time" ]]; then
  info "Installing mcp-server-time into MCP venv…"
  "$MCP_VENV/bin/pip" install --quiet mcp-server-time 2>/dev/null \
    && ok "mcp-server-time installed" \
    || warn "mcp-server-time install failed"
fi
if ! curl -sf --max-time 3 http://127.0.0.1:${MCP_TIME_PORT:-8010}/openapi.json >/dev/null 2>&1; then
  warn "MCP bridges down — starting..."
  "$BIN_DIR/llm-mcp-start" 2>/dev/null \
    && ok "MCP bridges started" \
    || fail "MCP bridges — run: llm-mcp-start"
else
  ok "MCP bridges — online"
fi

# PATH
if ! echo "$PATH" | grep -q "$HOME/.local/bin"; then
  warn "~/.local/bin not in PATH — fixing..."
  echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$HOME/.bashrc"
  export PATH="$HOME/.local/bin:$PATH"
  ok "PATH fixed (reload terminal or: source ~/.bashrc)"
else
  ok "PATH — ok"
fi

echo ""
echo -e "  ${DIM}Fixed: $FIXED  |  Could not fix: $UNFIXED${NC}"
if [[ $UNFIXED -gt 0 ]]; then
  echo -e "  ${BY}[~]${NC}  For unfixed issues, re-run the main installer: ${C}llm-setup${NC}"
fi
echo ""
