#!/usr/bin/env bash
set -uo pipefail
_LIB="$HOME/.local/share/llm-setup/lib"
[[ -f "$_LIB/colors.sh" ]] || _LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib"
[[ -f "$_LIB/colors.sh" ]] || { echo "llm-setup lib not found — re-run llm-setup" >&2; exit 1; }
source "$_LIB/colors.sh"
source "$_LIB/paths.sh"

mkdir -p "$MCP_PID_DIR"

# ── First-time install if mcpo is missing ─────────────────────────────────────
if [[ ! -x "$MCP_VENV/bin/mcpo" ]]; then
  echo -e "  ${BCYAN}→${NC}  MCP not installed yet — installing now (~5 MB)…"
  if ! curl -sf --max-time 3 https://pypi.org >/dev/null 2>&1 &&      ! curl -sf --max-time 3 https://files.pythonhosted.org >/dev/null 2>&1; then
    echo -e "  ${BRED}✘${NC}  No internet access — cannot install MCP" >&2; exit 1
  fi
  _py=$(command -v python3 || true)
  [[ -x "$_py" ]] || { echo -e "  ${BRED}✘${NC}  python3 not found" >&2; exit 1; }
  [[ -d "$MCP_VENV" && ! -f "$MCP_VENV/bin/activate" ]] && rm -rf "$MCP_VENV"
  "$_py" -m venv "$MCP_VENV" || { echo -e "  ${BRED}✘${NC}  Failed to create MCP venv" >&2; exit 1; }
  "$MCP_VENV/bin/pip" install --quiet --no-cache-dir --upgrade pip
  "$MCP_VENV/bin/pip" install --no-cache-dir mcpo mcp-server-time     || { echo -e "  ${BRED}✘${NC}  MCP install failed" >&2; exit 1; }
  echo -e "  ${BGREEN}✔${NC}  mcpo + mcp-server-time installed"

  # Write default config if missing
  if [[ ! -f "$CONF_DIR/mcp.conf" ]]; then
    mkdir -p "$CONF_DIR"
    cat > "$CONF_DIR/mcp.conf" << MCPCONF
MCP_TIME_PORT="${MCP_TIME_PORT}"
MCP_FS_PORT="${MCP_FS_PORT}"
MCP_VENV="${MCP_VENV}"
MCP_LOG="${MCP_LOG}"
MCP_PID_DIR="${MCP_PID_DIR}"
MCPCONF
  fi

  # Write default fs dirs if missing
  if [[ ! -f "$CONF_DIR/mcp_fs_dirs.txt" ]]; then
    printf '%s
' "$HOME" "$HOME/Documents" "$HOME/Downloads" > "$CONF_DIR/mcp_fs_dirs.txt"
    # WSL2 check
    grep -qi 'microsoft' /proc/version 2>/dev/null && printf '/mnt
' >> "$CONF_DIR/mcp_fs_dirs.txt" || true
  fi

  # Add bashrc hook
  if ! grep -qF "llm-mcp-start" "$HOME/.bashrc" 2>/dev/null; then
    printf '
# llm-setup: start MCP tool bridges
' >> "$HOME/.bashrc"
    printf '[ -x "$HOME/.local/bin/llm-mcp-start" ] && llm-mcp-start &>/dev/null &
' >> "$HOME/.bashrc"
    echo -e "  ${DIM}Added MCP auto-start to ~/.bashrc${NC}"
  fi
fi

# Load filesystem dirs
MCP_FS_DIRS=()
if [[ -f "$CONF_DIR/mcp_fs_dirs.txt" ]]; then
  while IFS= read -r _d; do [[ -d "$_d" ]] && MCP_FS_DIRS+=("$_d"); done \
    < "$CONF_DIR/mcp_fs_dirs.txt"
fi
[[ ${#MCP_FS_DIRS[@]} -eq 0 ]] && MCP_FS_DIRS=("$HOME")

_start_bridge() {
  local name="$1" port="$2"; shift 2
  local pid_file="$MCP_PID_DIR/mcpo-${name}.pid"
  local child_log="$MCP_LOG.${name}-child"
  if [[ -f "$pid_file" ]]; then
    local _pid; _pid=$(cat "$pid_file" 2>/dev/null || echo "")
    if [[ -n "$_pid" ]] && kill -0 "$_pid" 2>/dev/null; then
      echo -e "  ${DIM}mcpo/$name already running (PID $_pid)${NC}"; return 0
    fi
    rm -f "$pid_file"
  fi
  echo "Starting mcpo/$name on 127.0.0.1:$port — cmd: $*" >> "$MCP_LOG"
  nohup "$MCP_VENV/bin/mcpo" --host 127.0.0.1 --port "$port" -- "$@" \
    >> "$MCP_LOG" 2>> "$child_log" &
  local _pid=$!
  sleep 0.1
  echo "$_pid" > "$pid_file"
  disown "$_pid" 2>/dev/null
  echo -e "  ${CYAN}·${NC}  mcpo/$name started on :$port (PID $_pid)"
}

# time — runs directly from pip venv (no uvx, no download delay, no protocol drift)
if [[ -x "$MCP_VENV/bin/mcp-server-time" ]]; then
  _start_bridge time "$MCP_TIME_PORT" "$MCP_VENV/bin/mcp-server-time"
else
  echo -e "  ${BYELLOW}⚠${NC}  mcp-server-time not in venv — time bridge skipped"
  echo -e "     Fix: $MCP_VENV/bin/pip install mcp-server-time  then: llm-mcp-start"
fi

# filesystem — npx @modelcontextprotocol/server-filesystem (official Node package)
if command -v npx &>/dev/null; then
  _start_bridge filesystem "$MCP_FS_PORT" \
    npx -y @modelcontextprotocol/server-filesystem "${MCP_FS_DIRS[@]}"
else
  echo -e "  ${BYELLOW}⚠${NC}  npx not found — filesystem server skipped"
fi

# ── Verify ────────────────────────────────────────────────────────────────────
# mcp-server-time starts from venv directly — should be ready within a few seconds.
# Poll every 2s for up to 60s total per bridge.
_all_ok=1
for _pair in "time:$MCP_TIME_PORT" "filesystem:$MCP_FS_PORT"; do
  _n="${_pair%%:*}"; _p="${_pair##*:}"
  _ok=0
  for (( _i=0; _i<30; _i++ )); do
    sleep 2
    curl -sf --max-time 3 "http://127.0.0.1:${_p}/openapi.json" >/dev/null 2>&1 \
      && { _ok=1; break; }
  done
  if (( _ok )); then
    echo -e "  ${BGREEN}✔${NC}  mcpo/$_n  →  http://127.0.0.1:${_p}"
  else
    echo -e "  ${BYELLOW}⚠${NC}  mcpo/$_n not responding — check:"
    echo     "     tail -40 $MCP_LOG"
    echo     "     tail -40 ${MCP_LOG}.${_n}-child"
    _all_ok=0
  fi
done
(( _all_ok )) && exit 0 || exit 1
