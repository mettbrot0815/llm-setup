#!/usr/bin/env bash
# llm-models-refresh — fetch latest popular models from ollama.com and update local cache
# Cache: ~/.config/llm-setup/models-cache.sh  (sourced by catalog.sh if newer than 7 days)
set -uo pipefail

_LIB="$HOME/.local/share/llm-setup/lib"
[[ -f "$_LIB/colors.sh" ]] || _LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib"
[[ -f "$_LIB/colors.sh" ]] || { echo "llm-setup lib not found — re-run llm-setup" >&2; exit 1; }
source "$_LIB/colors.sh"
source "$_LIB/paths.sh"

CACHE_FILE="$CONF_DIR/models-cache.sh"

echo ""
echo -e "  ${BOLD}Model Catalog Refresh${NC}"
echo ""

if ! curl -sf --connect-timeout 5 --max-time 8 https://ollama.com >/dev/null 2>&1; then
  warn "No internet — using cached/built-in catalog"
  exit 0
fi

info "Fetching featured models from ollama.com…"

# Ollama search API — returns JSON array of model objects
_json=$(curl -sf --max-time 15 \
  -H "Accept: application/json" \
  "https://ollama.com/api/models?sort=featured&p=1&per_page=100" 2>/dev/null || true)

if [[ -z "$_json" ]] || ! echo "$_json" | python3 -c "import sys,json; json.load(sys.stdin)" 2>/dev/null; then
  warn "Could not fetch model list from ollama.com — using built-in catalog"
  exit 0
fi

# Parse JSON → generate _MODELS array entries
_new_models=$(python3 - "$_json" << 'PYEOF'
import sys, json, re

data = json.loads(sys.argv[1])

# Ollama API returns {"models": [...]} or just [...]
models = data if isinstance(data, list) else data.get("models", data.get("data", []))

# VRAM heuristics by parameter count (rough but consistent)
def vram_for(params_b):
    if params_b <= 0:   return "CPU"
    if params_b <= 2:   return "CPU"
    if params_b <= 4:   return "3"
    if params_b <= 8:   return "5"
    if params_b <= 12:  return "8"
    if params_b <= 15:  return "9"
    if params_b <= 23:  return "13"
    if params_b <= 30:  return "16"
    if params_b <= 35:  return "20"
    if params_b <= 72:  return "40"
    return "80"

def layers_for(params_b):
    if params_b <= 1:  return "28"
    if params_b <= 4:  return "36"
    if params_b <= 8:  return "36"
    if params_b <= 12: return "46"
    if params_b <= 15: return "48"
    if params_b <= 23: return "48"
    if params_b <= 35: return "64"
    if params_b <= 72: return "80"
    return "80"

def size_gb(params_b):
    if params_b <= 0: return "1"
    return str(max(1, round(params_b * 0.6)))

def quant(params_b):
    if params_b <= 2:  return "Q8"
    return "Q4"

def caps(name, tags):
    c = []
    n = name.lower()
    t = " ".join(str(x) for x in tags).lower()
    if any(x in n or x in t for x in ["tool", "function", "instruct", "qwen", "llama", "gemma", "mistral"]):
        c.append("tools")
    if any(x in n for x in ["r1", "think", "reason", "cot"]):
        c.append("think")
    return ",".join(c) if c else "tools"

seen = set()
rows = []
for m in models:
    name = m.get("name", "") or m.get("model_name", "")
    if not name or name in seen:
        continue
    seen.add(name)

    # Parse param count from name or model card fields
    params_b = 0
    pm = re.search(r"[:\-_](\d+(?:\.\d+)?)b", name.lower())
    if pm:
        try: params_b = float(pm.group(1))
        except: pass
    if params_b == 0:
        param_str = str(m.get("parameter_size", "") or m.get("params", "") or "")
        pm2 = re.search(r"(\d+(?:\.\d+)?)\s*[Bb]", param_str)
        if pm2:
            try: params_b = float(pm2.group(1))
            except: pass

    tag = name if ":" in name else name + ":latest"
    # clean display name
    display = re.sub(r"[:\-_]", " ", name).title().strip()
    tags_list = m.get("tags", []) or []

    row = (
        f'"{tag:<23} | {display:<24} | {quant(params_b):<3} | '
        f'{vram_for(params_b):<3} | {size_gb(params_b):<2} | '
        f'{layers_for(params_b):<3} | {caps(name, tags_list)}"'
    )
    rows.append(row)

if rows:
    print("_MODELS=(")
    for r in rows[:60]:  # cap at 60 models
        print(r)
    print(")")
PYEOF
)

if [[ -z "$_new_models" ]]; then
  warn "Parsing failed — using built-in catalog"
  exit 0
fi

_count=$(echo "$_new_models" | grep -c '"' || echo 0)

cat > "$CACHE_FILE" << CACHE
# llm-setup model cache — auto-generated by llm-models-refresh
# Generated: $(date -u +"%Y-%m-%d %H:%M UTC")
# Source: ollama.com/api/models
${_new_models}
CACHE

ok "Catalog updated: $_count models cached"
info "Cache: $CACHE_FILE"
info "Run llm-add or llm-switch to see updated list"
echo ""
